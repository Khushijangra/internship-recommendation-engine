# Frontend environment configuration
# Copy this file to .env and fill in your actual Firebase project values.
# Get these from: Firebase Console → Project Settings → Your Apps → SDK setup
# NEVER commit frontend/.env — it is blocked by .gitignore

# ---------------------------------------------------------------------------
# Firebase — Required
# ---------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=your_firebase_web_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_numeric_sender_id
VITE_FIREBASE_APP_ID=1:your_sender_id:web:your_app_hash

# ---------------------------------------------------------------------------
# Backend API URL
# ---------------------------------------------------------------------------
# Local development
VITE_API_URL=http://localhost:8000
# Production (uncomment and set your Railway URL)
# VITE_API_URL=https://your-app.railway.app
